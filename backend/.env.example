# ─── Quantum Vector Backend — Environment Variables ───────────────────────────
# Copy to .env and fill in values. NEVER commit .env to git.

NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5000,https://quantumvector.sh,https://quantumvector.io

# Email (Nodemailer — use Gmail App Password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hr@quantumvector.sh
SMTP_PASS=your_app_password_here
SMTP_FROM="Quantum Vector <hr@quantumvector.sh>"
NOTIFY_EMAIL=hr@quantumvector.sh

# Razorpay (for payment link generation)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# JWT (for student login, future feature)
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
